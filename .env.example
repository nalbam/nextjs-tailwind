# ─────────────────────────────────────────────────────────────
# Required
# ─────────────────────────────────────────────────────────────

# Generate with: openssl rand -base64 32
# Minimum 32 characters. Without this, getServerEnv() throws.
BETTER_AUTH_SECRET=

# ─────────────────────────────────────────────────────────────
# Better Auth (server)
# ─────────────────────────────────────────────────────────────

# Public URL the auth server is reachable at. Defaults to http://localhost:3000.
BETTER_AUTH_URL="http://localhost:3000"

# Comma-separated list of additional origins allowed to call the auth API
# (in addition to BETTER_AUTH_URL). Required for production with custom domains.
# TRUSTED_ORIGINS="https://app.example.com,https://admin.example.com"

# ─────────────────────────────────────────────────────────────
# Better Auth (client)
# ─────────────────────────────────────────────────────────────

NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Next.js Tailwind Starter"

# Toggle the email/password form on /login and /signup. Defaults to enabled;
# set to "false" to hide it entirely (server also disables emailAndPassword).
# NEXT_PUBLIC_AUTH_EMAIL_ENABLED="true"

# Set to "true" to render the "Continue with Google" button on /login and /signup.
# The server still requires AUTH_GOOGLE_ID and AUTH_GOOGLE_SECRET to actually accept
# the redirect; set both to enable end-to-end.
# NEXT_PUBLIC_AUTH_GOOGLE_ENABLED="true"

# ─────────────────────────────────────────────────────────────
# AWS
# ─────────────────────────────────────────────────────────────

AWS_REGION="ap-northeast-2"

# Optional. If unset, the default AWS credential chain is used.
# In Amplify Hosting, prefer attaching an IAM role to the SSR compute role.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ─────────────────────────────────────────────────────────────
# DynamoDB
# ─────────────────────────────────────────────────────────────

DYNAMODB_TABLE_NAME="app-main"

# Set to point at DynamoDB Local during development.
# Leave empty in production to use the real DynamoDB endpoint.
DYNAMODB_ENDPOINT="http://localhost:8000"

# ─────────────────────────────────────────────────────────────
# Session/rate-limit KV (Better Auth secondaryStorage)
# ─────────────────────────────────────────────────────────────

# Local development: use Valkey/Redis via docker-compose.
REDIS_URL="redis://localhost:6379"

# Production (Amplify): use Upstash Redis REST. If both are set, Upstash wins.
# UPSTASH_REDIS_REST_URL="https://<your-instance>.upstash.io"
# UPSTASH_REDIS_REST_TOKEN=

# ─────────────────────────────────────────────────────────────
# Auth methods (optional)
# ─────────────────────────────────────────────────────────────

# Toggle the email/password sign-in path server-side. Defaults to enabled.
# Set to "false" to disable Better Auth's emailAndPassword provider.
# AUTH_EMAIL_ENABLED="true"

# Google OAuth client. Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# ─────────────────────────────────────────────────────────────
# Transactional email (optional)
# ─────────────────────────────────────────────────────────────

# Verified sender for AWS SES. When set, src/lib/email.ts uses SES via the
# default AWS credential chain (Amplify SSR compute role recommended).
# Leave empty for a console-only fallback in dev.
# AWS_SES_FROM="no-reply@example.com"

# ─────────────────────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────────────────────

# Optional. One of: debug, info, warn, error. Defaults: dev=debug, prod=info.
# LOG_LEVEL=info
